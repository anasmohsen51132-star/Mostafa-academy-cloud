# ============================================================
# MUSTAFA ACADEMY — Environment Variables
# Copy this file to .env.local and fill in real values
# ============================================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/mustafa_academy"

# JWT Secret — generate with: openssl rand -base64 64
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES_IN="7d"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Upload (optional — Vercel Blob or local)
BLOB_READ_WRITE_TOKEN="your-vercel-blob-token"

# Owner seed credentials (used in prisma/seed.ts)
OWNER_PHONE="01000000000"
OWNER_PASSWORD="owner1234"
OWNER_NAME="مستر مصطفى"
